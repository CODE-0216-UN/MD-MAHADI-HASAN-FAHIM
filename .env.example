# GEMINI_API_KEY1: Required for Hana AI Assistant on your live Vercel deployment.
# Configure this key in Vercel's Environment Variables settings.
GEMINI_API_KEY1="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
